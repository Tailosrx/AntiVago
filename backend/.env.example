# Backend Environment Variables

# ===== API KEYS =====
GOOGLE_API_KEY=your_gemini_api_key_here

# ===== TROPHY GENERATION =====
# Set to 'false' to disable Gemini API calls and use generic fallback trophies
# This prevents quota exceeded errors from the free tier
# Default: true (use Gemini if API key is available)
ENABLE_TROPHY_GENERATION=false

# ===== DATABASE =====
DATABASE_URL=your_database_url_here

# ===== JWT =====
JWT_SECRET=your_jwt_secret_here

# ===== SERVER =====
PORT=3000
NODE_ENV=development
